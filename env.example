# Environment Variables Reference

Copy this file to `.env` and fill in your values.
Never commit `.env` to version control.

# ============================================================================
# KDB+ Storage Layer
# ============================================================================

# Bearer token required for all HTTP API calls to http_gateway.q (except /health, /metrics)
ROBIN_KDB_API_TOKEN=

# Optional IPC password for direct KDB+ inter-process connections
ROBIN_KDB_IPC_PW=

# ============================================================================
# Regulatory Reporting (R analytics)
# REQUIRED before generating any SEC CAT reports
# ============================================================================

# Your firm's SEC CAT FirmID (assigned by FINRA/SEC)
ROBIN_FIRM_ID=

# Your firm's CRD number
ROBIN_CRD_NUM=

# ============================================================================
# Go Orchestrator / Gateway
# ============================================================================

# HTTP listen port (default: 8080)
ORCH_PORT=8080

# TLS certificate and key files (leave empty to disable TLS, use plain HTTP)
ORCH_TLS_CERT=
ORCH_TLS_KEY=

# ============================================================================
# Frontend
# ============================================================================

# Gateway base URL (default: http://localhost:8080)
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080

# ============================================================================
# Compliance Daemon (Rust)
# ============================================================================

# Prometheus metrics port for compliance daemon (default: 9095)
COMPLIANCE_METRICS_PORT=9095

# Audit log directory (SHA-256 WORM log)
COMPLIANCE_AUDIT_LOG_DIR=./logs/compliance
