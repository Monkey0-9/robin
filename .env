# ─────────────────────────────────────────────────────────────────────────────
# QUANTUM TERMINAL — Environment Variables Template
# IMPORTANT: Copy to .env and fill in real values. NEVER commit .env to git.
# All API keys must be loaded from Vault/AWS Secrets Manager in production.
# ─────────────────────────────────────────────────────────────────────────────

# ── SYSTEM ────────────────────────────────────────────────────────────────────
# Options: sandbox | paper | live
# sandbox = local matching engine only (safe for development)
# paper   = broker paper trading endpoints (no real capital)
# live    = REAL MONEY — requires MFA confirmation + ADMIN role
TRADING_MODE=sandbox

# Application environment
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX_SECRET

# ── INFRASTRUCTURE ─────────────────────────────────────────────────────────────
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD
POSTGRES_USER=qt_admin
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_POSTGRES_PASSWORD
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ── QUESTDB ───────────────────────────────────────────────────────────────────
QUESTDB_HOST=questdb
QUESTDB_ILP_PORT=9009
QUESTDB_HTTP_PORT=9000
QUESTDB_PG_PORT=8812

# ── EXCHANGE APIs ─────────────────────────────────────────────────────────────
# Binance (Crypto)
BINANCE_API_KEY=REPLACE_WITH_BINANCE_API_KEY
BINANCE_API_SECRET=REPLACE_WITH_BINANCE_API_SECRET
# Use testnet for sandbox mode
BINANCE_WS_URL=wss://stream.binance.com:9443
BINANCE_TESTNET_WS_URL=wss://testnet.binance.vision

# Coinbase Advanced Trade (Crypto)
COINBASE_API_KEY=REPLACE_WITH_COINBASE_API_KEY
COINBASE_API_SECRET=REPLACE_WITH_COINBASE_API_SECRET
COINBASE_WS_URL=wss://advanced-trade-ws.coinbase.com

# Alpaca (Equities - Paper Trading)
ALPACA_API_KEY=REPLACE_WITH_ALPACA_API_KEY
ALPACA_API_SECRET=REPLACE_WITH_ALPACA_API_SECRET
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_WS_URL=wss://stream.data.alpaca.markets/v2/iex

# OANDA (Forex)
OANDA_ACCOUNT_ID=REPLACE_WITH_OANDA_ACCOUNT_ID
OANDA_API_KEY=REPLACE_WITH_OANDA_API_KEY
# Use practice environment for sandbox/paper
OANDA_REST_URL=https://api-fxpractice.oanda.com
OANDA_STREAM_URL=https://stream-fxpractice.oanda.com

# ── AI / NLP ──────────────────────────────────────────────────────────────────
# FinBERT model path (local) or Hugging Face model ID
FINBERT_MODEL=ProsusAI/finbert
# Set to 'local' for RTX 3050 inference, 'hf-api' for Hugging Face Endpoints
FINBERT_INFERENCE_MODE=local
HF_API_TOKEN=REPLACE_WITH_HUGGINGFACE_API_TOKEN

# GDELT Alternative Data Feed
GDELT_BASE_URL=http://data.gdelt.project/gdeltv2/lastupdate.txt

# ── ALTERNATIVE DATA ──────────────────────────────────────────────────────────
# SpaceKnow (satellite imagery) - freemium
SPACEKNOW_API_KEY=REPLACE_WITH_SPACEKNOW_API_KEY
# MarineTraffic (shipping AIS) - freemium
MARINETRAFFIC_API_KEY=REPLACE_WITH_MARINETRAFFIC_API_KEY

# ── NOTIFICATIONS ─────────────────────────────────────────────────────────────
# Twilio (SMS + Voice emergency alerts)
TWILIO_ACCOUNT_SID=REPLACE_WITH_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=REPLACE_WITH_TWILIO_AUTH_TOKEN
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_ALERT_TO_NUMBER=+1XXXXXXXXXX

# Telegram Bot (real-time P&L + manual override)
TELEGRAM_BOT_TOKEN=REPLACE_WITH_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=REPLACE_WITH_TELEGRAM_CHAT_ID

# SendGrid (email notifications)
SENDGRID_API_KEY=REPLACE_WITH_SENDGRID_API_KEY
ALERT_EMAIL_FROM=alerts@your-domain.com
ALERT_EMAIL_TO=your-email@domain.com

# ── SECURITY ──────────────────────────────────────────────────────────────────
# JWT Configuration
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# HashiCorp Vault (development - use AWS Secrets Manager in production)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=REPLACE_WITH_VAULT_DEV_TOKEN

# AWS Secrets Manager (production)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE_WITH_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_AWS_SECRET_KEY

# ── RISK PARAMETERS (DEFAULTS — overridden by user profiles) ─────────────────
# Maximum single-asset exposure as % of total account equity
MAX_SINGLE_ASSET_EXPOSURE_PCT=5.0
# Maximum sector exposure as % of total account equity
MAX_SECTOR_EXPOSURE_PCT=20.0
# Daily loss ceiling (halt trading if exceeded)
MAX_DAILY_LOSS_PCT=3.0
# Weekly loss ceiling
MAX_WEEKLY_LOSS_PCT=8.0
# Monthly loss ceiling
MAX_MONTHLY_LOSS_PCT=15.0
# Minimum AI confidence to allow trade execution (0.0-1.0)
MIN_AI_CONFIDENCE_THRESHOLD=0.65
# Pre-trade risk gate max execution budget (milliseconds)
RISK_GATE_MAX_LATENCY_MS=1.0

# ── MONITORING ────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_GRAFANA_PASSWORD
